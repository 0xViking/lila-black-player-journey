# Raw dataset - NOT committed (see README "Setup"). ~26 MB; place it here yourself.
/data/

# Node
node_modules/
web/node_modules/

# Build output (regenerated by the deploy platform)
web/dist/
dist/
*.tsbuildinfo

# Claude Code / local agent tooling (not part of the app)
.claude/
CLAUDE.md
MEMORY.md

# Python
__pycache__/
*.pyc

# Editor / OS
.DS_Store
.vscode/
.idea/
*.log

# Deploy CLIs
.vercel/

# NOTE: web/public/data/*.json and web/public/minimaps/* ARE committed on purpose,
# so the app builds, runs and deploys without needing the raw Parquet.
